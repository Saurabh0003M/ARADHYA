# Aradhya Configuration

# Application
APP_NAME=Aradhya
ENV=development
DEBUG=True

# Paths (Windows paths use double backslashes or forward slashes)
PROJECT_ROOT=F:/ARADHYA
LOGS_DIR=F:/ARADHYA/core/logs
DATA_DIR=F:/ARADHYA/data

# API Keys (add your keys here)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...

# Logging
LOG_LEVEL=INFO
