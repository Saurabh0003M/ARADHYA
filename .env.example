# Aradhya Configuration

# Application
APP_NAME=Aradhya
ENV=development
DEBUG=True

# Paths
# Use paths that make sense on the current machine if you create a local .env.
# The application code itself already resolves repo-relative defaults.
PROJECT_ROOT=.
LOGS_DIR=core/logs
DATA_DIR=data

# API Keys (add your keys here)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...

# Logging
LOG_LEVEL=INFO
