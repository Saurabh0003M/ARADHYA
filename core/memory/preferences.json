{
  "directory_index_path": "project_tree.txt",
  "context_cache_dir": "data/processed/context",
  "confirmation_phrases": [
    "yes proceed",
    "proceed",
    "confirm",
    "go ahead"
  ],
  "security_blog_urls": [
    "https://krebsonsecurity.com/",
    "https://thehackernews.com/",
    "https://www.bleepingcomputer.com/"
  ],
  "project_markers": [
    "pyproject.toml",
    "package.json",
    "requirements.txt",
    "Cargo.toml",
    ".git"
  ],
  "game_library_roots": [],
  "allow_live_execution": false,
  "directory_index_policy": {
    "refresh_on_wake": true,
    "refresh_on_local_query": true,
    "refresh_interval_seconds": 60,
    "ignored_names": [
      ".git",
      "__pycache__",
      "appdata",
      "cache",
      "node_modules",
      "temp",
      "tmp",
      "venv"
    ],
    "max_nodes": 25000,
    "max_name_candidates_per_key": 25,
    "miss_cache_ttl_seconds": 300,
    "miss_refresh_debounce_seconds": 2.0
  }
}
