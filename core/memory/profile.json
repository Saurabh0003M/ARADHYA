    "manual_transcripts_dir": "audio/manual_transcripts",
    "supported_extensions": [
      ".aac",
      ".flac",
      ".m4a",
      ".mp3",
      ".ogg",
      ".opus",
      ".wav"
    ],
    "whisper_command_template": null,
    "faster_whisper_model_size": "base",
    "faster_whisper_device": "cpu",
    "faster_whisper_compute_type": "int8",
    "language": null,
    "poll_on_wake": true
  }
}
